```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.coverage
.pytest_cache/
.mypy_cache/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
jspm_packages/

# Build outputs
dist/
build/
*.min.js
*.min.css

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
```